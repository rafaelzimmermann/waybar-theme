#!/usr/bin/env bash
#
# Caffeine toggle — disable/enable hyprlock via hypridle
#
# Steam rising from cup = ON  (hypridle killed, screen won't lock)
# Plain cup             = OFF (hypridle running, screen locks on idle)

ICONS="$HOME/.config/waybar/icons"

get_status() {
    if pgrep -x hypridle > /dev/null; then
        echo "$ICONS/caffeine-inactive.png"
    else
        echo "$ICONS/caffeine-active.png"
    fi
}

case "$1" in
    toggle)
        if pgrep -x hypridle > /dev/null; then
            pkill -x hypridle
        else
            hypridle &
        fi
        pkill -SIGRTMIN+8 waybar
        ;;
    *)
        get_status
        ;;
esac
