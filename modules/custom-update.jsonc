{
    "custom/update": {
        "exec": "~/.config/waybar/scripts/update module",
        "return-type": "json",
        "interval": 3600,
        "signal": 1,
        "format": "{}",
        "on-click": "hyprctl dispatch exec \"[float;center;size 600 400] ghostty -e ~/.config/waybar/scripts/update\"",
        "on-click-right": "pkill -RTMIN+1 waybar"
    }
}
