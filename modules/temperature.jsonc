{
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon8/temp1_input",
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-critical": "≤░Αο {temperatureC}┬░C",
        "format-icons": ["≤▒ΔΔ", "≤░ΦΠ", "≤▒ΔΓ"],
        "tooltip-format": "Fahrenheit: {temperatureF}┬░F"
    }
}
